# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# Anthropic Claude API Key
# 获取地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenAI GPT API Key
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# DeepSeek API Key（可选，Day 2 扩展用）
# DEEPSEEK_API_KEY=sk-your_deepseek_key

# 默认 LLM 配置
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096

# [DEBUG] 压缩触发比例覆盖（对齐 Claude Code CLAUDE_AUTOCOMPACT_PCT_OVERRIDE）
# 语义：剩余百分比（和 Claude Code 一致）
# 留空 = 使用固定缓冲模式（GLM 13K buffer, Claude 13K buffer）
# 设为 25 = 剩余 ≤ 25% 时触发压缩（即已用 ≥ 75%）
# 设为 10 = 剩余 ≤ 10% 时触发压缩（即已用 ≥ 90%）
# 示例：AUTOCOMPACT_PCT_OVERRIDE=25
# AUTOCOMPACT_PCT_OVERRIDE=25

# ─────────────────────────────────────────────
# 记忆任务 WAL 状态机 (M11)
# ─────────────────────────────────────────────
# 记忆任务状态机配置 — Phase 3 接入
# 缺字段 = 走 TaskWALConfig 默认 (max_retry=3, backoff=60s,
# done/failed_retention=86400s = 1 day)
#
# FAILED 任务最大重试次数。attempts >= max_attempts 后视为终态,
# startup_scan 步骤 1b 清理(默认 1 天后)。
MEMORY_WAL__MAX_RETRY=3

# 退避基准秒数。退避公式: next_at = now + retry_backoff_seconds × 2^(attempts-1)
# 60s 基准 → 60s / 120s / 240s / 480s ...
MEMORY_WAL__RETRY_BACKOFF_SECONDS=60

# DONE 行保留时间(startup_scan 步骤 1a 清理)。
# 留 *_DAYS 走 days 写法(自动 × 86400 转秒),也可直接给 *_SECONDS。
MEMORY_WAL__DONE_RETENTION_DAYS=1

# 终态 FAILED 行保留时间(startup_scan 步骤 1b 清理)。
MEMORY_WAL__FAILED_RETENTION_DAYS=1

# ────────────────────────────────────────────────────────────────
# 记忆系统 (M11, 2026-06-26 改读 .env)
# 命名约定: MEMORY_<SECTION>__<FIELD> (双下划线分隔嵌套)
# 不设则用 MemoryConfig 默认值
# 改完 .env 后需重启 streamlit
# ────────────────────────────────────────────────────────────────

# 检索模式: semantic (向量召回) | side_query (LLM 二次精选)
# MEMORY_RETRIEVAL__MODE=side_query

# 召回条数 (1-20)
# MEMORY_RETRIEVAL__TOP_K=5

# sideQuery 模式单次最多选几个 path (1-10)
# MEMORY_RETRIEVAL__SIDE_QUERY_MAX_SELECT=5

# 提取日预算 (USD)
# MEMORY_COST__DAILY_BUDGET_USD=1.0
